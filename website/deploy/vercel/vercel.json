{
  "installCommand": "pip install -r deploy/vercel/requirements-vercel.txt",
  "buildCommand": "bash deploy/vercel/build.sh",
  "builds": [
    {
      "src": "website/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "website/wsgi.py"
    }
  ]
}

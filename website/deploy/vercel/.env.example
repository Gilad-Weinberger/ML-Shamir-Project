# Vercel production: set these in the dashboard (Settings → Environment Variables).
# Local dev: use website/.env.example → copy to website/.env.local (see deploy/vercel/GUIDE.md).
# See deploy/vercel/GUIDE.md for where to get each value

# --- Django (Vercel + optional local) ---
# Generate: random 50+ char string
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# Vercel: False | Local: omit or True
DEBUG=False
# Vercel: your-app.vercel.app and/or .vercel.app
ALLOWED_HOSTS=.vercel.app,your-app.vercel.app

# --- Supabase (from supabase.com → Project Settings → API) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=leaf-uploads

# --- Hugging Face Space (from your Space URL + settings/tokens) ---
HF_INFERENCE_URL=https://YOUR_USERNAME-grape-leaf-inference.hf.space
# Only if Space or model repo is PRIVATE. Public Space: leave empty / delete on Vercel.
# Must be a Read token from https://huggingface.co/settings/tokens (starts with hf_)
# Do NOT put this in SUPABASE_SERVICE_ROLE_KEY — that field is a Supabase JWT (eyJ...).
HF_TOKEN=

# --- Optional: local .pth download only (not needed on Vercel) ---
HF_MODEL_REPO=YOUR_USERNAME/grape-leaf-5deg
HF_MODEL_FILE=grape_leaf_model_5deg.pth

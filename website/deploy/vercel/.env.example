# Django production settings (Vercel)
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=.vercel.app,your-domain.com

# Supabase Storage (upload previews)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=leaf-uploads

# Hugging Face inference Space (see deploy/huggingface/GUIDE.md)
HF_INFERENCE_URL=https://YOUR_USERNAME-grape-leaf-inference.hf.space
HF_TOKEN=

# Optional: download weights for local-like behavior (not used when HF_INFERENCE_URL is set)
HF_MODEL_REPO=YOUR_USERNAME/grape-leaf-5deg
HF_MODEL_FILE=grape_leaf_model_5deg.pth
